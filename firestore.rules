rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.nickname is string && data.nickname.size() <= 32 &&
             data.pin is string && data.pin.size() == 4 &&
             data.avatar is string &&
             data.totalLitres is number &&
             data.totalBeers is number &&
             data.streakCurrent is number &&
             data.streakLongest is number &&
             data.rankTitle is string;
    }

    function isValidPost(data) {
      return data.userId is string &&
             data.nickname is string &&
             data.avatar is string &&
             data.photoUrl is string &&
             (data.amount == 0.3 || data.amount == 0.5) &&
             data.timestamp is timestamp &&
             data.totalLitresAfter is number &&
             data.reactions is map;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if true; // Public profiles
      allow list: if true; // For leaderboards
      allow create: if isValidUser(incoming());
      allow update: if (
        // Allow anonymous updates for demo, but strictly check fields
        isValidUser(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasAny(['totalLitres', 'totalBeers', 'lastBeerDate', 'streakCurrent', 'streakLongest', 'rankTitle', 'avatar'])
      );
    }

    match /posts/{postId} {
      allow read: if true; // Public feed
      allow create: if isValidPost(incoming());
      allow update: if (
        isValidPost(incoming()) &&
        // Only allow updating reactions
        incoming().diff(existing()).affectedKeys().hasOnly(['reactions'])
      );
    }
  }
}
